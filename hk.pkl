amends "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Builtins.pkl"

local frontend = new Group {
	dir = "frontend"
	workspace_indicator = "pnpm.yaml"
	steps {
		["biome"] = (Builtins.biome)
		// ["stylelint"] = (Builtins.stylelint)
	}
}

local backend = new Group {
	workspace_indicator = "Cargo.toml"
	steps {
	["cargo_fmt"] = Builtins.cargo_fmt
	["cargo_clippy"] = Builtins.cargo_clippy
	["cargo_check"] = (Builtins.cargo_check) {
		// Only run in CI or with "full" profile.
		profiles = List("ci", "full")
	}
  }
}

local shared = new Mapping<String, Step> {
	["yaml"] = (Builtins.yamllint) {
		glob = List("**/*.yaml", "**/*.yml")
		exclude = List("**/node_modules/**", "**/pnpm-lock.yaml")
	}
	["trailing-whitespace"] = Builtins.trailing_whitespace,
	["mixed-line-ending"] = Builtins.mixed_line_ending,
	// ["end-of-file-fixer"] = Builtins.end_of_file_fixer,
	["fix-smart-quotes"] = Builtins.fix_smart_quotes,
	["check-case-conflict"] = Builtins.check_case_conflict,
	["check-executables-have-shebangs"] = Builtins.check_executables_have_shebangs,
}

hooks {
	["pre-commit"] {
		fix = true
		stash = "git"
		steps = {
			["frontend"] = frontend,
			["backend"] = backend,
			...shared,
			["check-merge-conflict"] = Builtins.check_merge_conflict,
			["check-added-large-files"] = Builtins.check_added_large_files,
			["detect-private-key"] = Builtins.detect_private_key,
		}
	}
	["commit-msg"] {
		steps {
			["check-conventional-commit"] {
				check = "hk util check-conventional-commit .git/COMMIT_EDITMSG"
			}
		}
	}
	["fix"] {
		fix = true
		steps = {
			["frontend"] = frontend,
			["backend"] = backend,
			...shared,
		}
	}
	["check"] {
		steps = {
			["frontend"] = frontend,
			["backend"] = backend,
			...shared,
		}
	}
}
