{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": { "ignoreUnknown": false, "includes": ["**", "!finance-api/.sqlx"] },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineEnding": "lf",
		"lineWidth": 100,
		"bracketSameLine": false,
		"bracketSpacing": true,
		"expand": "auto",
		"useEditorconfig": true,
		"includes": [
			"**",
			"!**/build",
			"!**/.next",
			"!**/coverage",
			"!**/node_modules",
			"!**/pnpm-lock.yaml"
		]
	},
	"linter": {
		"enabled": true
	},
	"javascript": {
		"formatter": {
			"trailingCommas": "all"
		}
	},
	"html": {
		"formatter": {
			"indentScriptAndStyle": false,
			"selfCloseVoidElements": "always"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": { "source": { "organizeImports": "on" } }
	}
}
