{
	"$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
	"spaces": 2,
	"generator-cli": {
		"version": "7.23.0",
		"useDocker": true,
		"generators": {
			"core": {
				"inputSpec": "./openapi.json",
				"generatorName": "typescript-fetch",
				"output": "#{cwd}/src/api/generated/",
				"additionalProperties": {
					"npmName": "api",
					"supportsES6": true,
					"withInterfaces": true
				}
			}
		}
	}
}
