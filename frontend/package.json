{
	"name": "finance-tools",
	"version": "0.1.0",
	"private": false,
	"license": "MIT",
	"homepage": "https://finance.oliverflecke.me",
	"engines": {
		"node": "^26"
	},
	"packageManager": "pnpm@11.5.0",
	"scripts": {
		"start-server": "pnpm build && pnpm start",
		"dev": "concurrently --kill-others --names \"JS,CSS\" -c \"bgBlue.bold,bgGreen.bold\" \"pnpm dev:js\" \"pnpm css\"",
		"css": "cross-env TAILWIND_MODE=watch pnpm postcss src/main.css -o src/compiled.css -v --watch",
		"dev:js": "next dev --experimental-https --turbo",
		"dev:https": "node server.js",
		"lint": "biome lint --write",
		"fmt": "biome format --write",
		"start": "next start",
		"prebuild": "pnpm postcss src/main.css -o src/compiled.css -v",
		"build": "next build",
		"test": "jest --watch",
		"openapi-generate-spec": "cargo run --manifest-path ../finance-api/Cargo.toml --features openapi openapi > ./openapi.json",
		"openapi-generate-client": "openapi-generator-cli generate && pnpm -C src/api/generated build",
		"openapi": "pnpm openapi-generate-spec && pnpm openapi-generate-client",
		"deploy": "pnpm run build && wrangler deploy",
		"preview": "pnpm run build && wrangler dev"
	},
	"dependencies": {
		"@api/finance": "link:src/api/generated/dist",
		"@auth0/auth0-react": "^2.20.0",
		"@auth0/auth0-spa-js": "^2.23.0",
		"@oliverflecke/components-react": "^0.7.0",
		"@tanstack/react-query": "^5.101.2",
		"@visx/axis": "^4.0.0",
		"@visx/curve": "^4.0.0",
		"@visx/group": "^4.0.0",
		"@visx/legend": "^4.0.0",
		"@visx/mock-data": "^4.0.0",
		"@visx/responsive": "^4.0.0",
		"@visx/scale": "^4.0.0",
		"@visx/shape": "^4.0.0",
		"@visx/xychart": "^4.0.0",
		"clsx": "^2.1.1",
		"d3-array": "^3.2.4",
		"dotenv": "^17.4.2",
		"file-saver": "^2.0.5",
		"immutability-helper": "^3.1.1",
		"react": "19.2.7",
		"react-async-hook": "^4.0.0",
		"react-dnd": "^16.0.1",
		"react-dnd-html5-backend": "^16.0.1",
		"react-dom": "19.2.7",
		"react-hook-form": "^7.81.0",
		"react-icons": "^5.7.0",
		"react-number-format": "^5.4.5",
		"react-spring": "^10.0.4",
		"web-vitals": "^5.3.0"
	},
	"devDependencies": {
		"@babel/core": "^7.22.9",
		"@babel/preset-env": "^7.22.9",
		"@babel/preset-react": "^7.22.5",
		"@babel/preset-typescript": "^7.22.5",
		"@biomejs/biome": "2.4.16",
		"@commitlint/cli": "^17.6.7",
		"@commitlint/config-conventional": "^17.6.7",
		"@css-modules-kit/ts-plugin": "^1.2.0",
		"@openapitools/openapi-generator-cli": "^2.38.0",
		"@testing-library/jest-dom": "^5.17.0",
		"@testing-library/react": "^14.0.0",
		"@testing-library/user-event": "^14.1.1",
		"@types/d3-array": "^3.0.5",
		"@types/d3-scale": "^4.0.3",
		"@types/file-saver": "^2.0.3",
		"@types/jest": "^29.5.3",
		"@types/node": "^20.4.4",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@types/uuid": "^9.0.2",
		"autoprefixer": "^10.4.14",
		"babel-jest": "^29.6.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"concurrently": "^8.2.0",
		"cross-env": "^7.0.3",
		"cssnano": "^6.0.1",
		"cypress": "^12.17.2",
		"gh-pages": "^5.0.0",
		"husky": "^8.0.3",
		"jest": "^29.6.1",
		"next": "16.2.9",
		"postcss": "^8.4.27",
		"postcss-cli": "^10.1.0",
		"postcss-import": "^15.1.0",
		"postcss-nested": "^6.0.1",
		"prettier-plugin-tailwindcss": "^0.4.1",
		"tailwindcss": "^3.3.3",
		"ts-node": "^10.2.1",
		"typescript": "^5.1.6",
		"wrangler": "^4.103.0"
	},
	"browserslist": {
		"production": [">0.2%", "not dead", "not op_mini all"],
		"development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
	}
}
